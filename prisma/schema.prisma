generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  apiTokens     ApiToken[]
  ownedProjects Project[]       @relation("ProjectOwner")
  memberships   ProjectMember[]
  sessions      Session[]
  buckets       StorageBucket[]
  tickets       SupportTicket[]
  ticketReplies TicketReply[]   @relation("TicketReplyAuthor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id        String    @id @default(cuid())
  name      String
  token     String    @unique
  scopes    String    @default("[\"read\"]")
  userId    String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique @default("")
  description    String                @default("")
  gitUrl         String                @default("")
  framework      String                @default("")
  buildCommand   String                @default("npm run build")
  outputDir      String                @default("out")
  installCommand String                @default("npm install")
  userId         String
  alias          String?               @default("")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deployments    Deployment[]
  protection     DeploymentProtection?
  domains        Domain[]
  envVars        EnvVar[]
  notifications  NotificationChannel[]
  user           User                  @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  functions      ProjectFunction[]
  members        ProjectMember[]
  redirects      ProjectsRedirect[]
  webhooks       Webhook[]
  cdnRules       CdnCacheRule[]
  cdnEdgeConfig  CdnEdgeConfig?
  cdnPurgeLogs   CdnPurgeLog[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Domain {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  verified       Boolean  @default(false)
  sslEnabled     Boolean  @default(false)
  sslProvisioned Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model EnvVar {
  id        String   @id @default(cuid())
  projectId String
  key       String
  value     String   @default("")
  buildTime Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
}

model Webhook {
  id           String   @id @default(cuid())
  projectId    String
  url          String
  secret       String   @default("")
  events       String   @default("[\"push\"]")
  active       Boolean  @default(true)
  githubRepo   String?  @default("")
  githubHookId String?  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model NotificationChannel {
  id        String   @id @default(cuid())
  projectId String
  type      String   @default("slack")
  url       String
  events    String   @default("[\"deploy.success\",\"deploy.failed\"]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeploymentProtection {
  id        String  @id @default(cuid())
  projectId String  @unique
  enabled   Boolean @default(false)
  password  String  @default("")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectsRedirect {
  id          String   @id @default(cuid())
  projectId   String
  source      String
  destination String
  type        String   @default("permanent")
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectFunction {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  method     String   @default("ANY")
  runtime    String   @default("nodejs")
  sourcePath String   @default("")
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model Deployment {
  id        String   @id @default(cuid())
  projectId String
  status    String   @default("pending")
  logs      String   @default("")
  branch    String   @default("main")
  commitSha String   @default("")
  commitMsg String   @default("")
  url       String   @default("")
  alias     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String
  subject   String
  category  String        @default("general")
  status    String        @default("open")
  priority  String        @default("normal")
  projectId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketReply[]

  @@index([userId])
}

model TicketReply {
  id        String        @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())
  author    User          @relation("TicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model StorageBucket {
  id         String   @id @default(cuid())
  name       String
  userId     String
  projectId  String?
  visibility String   @default("public")
  region     String   @default("us-east-1")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model CdnCacheRule {
  id        String   @id @default(cuid())
  projectId String
  ruleId    String
  pattern   String
  ttl       String   @default("60")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ruleId])
}

model CdnEdgeConfig {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  minTtl                 Int      @default(60)
  maxTtl                 Int      @default(31536000)
  staleWhileRevalidate   Int      @default(86400)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CdnPurgeLog {
  id        String   @id @default(cuid())
  projectId String
  path      String
  status    String   @default("completed")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
