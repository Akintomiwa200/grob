generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  ownedProjects Project[]    @relation("ProjectOwner")
  memberships   ProjectMember[]
  apiTokens     ApiToken[]
  tickets       SupportTicket[]
  ticketReplies TicketReply[] @relation("TicketReplyAuthor")
  buckets       StorageBucket[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique
  scopes    String   @default("[\"read\"]")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
}

model Project {
  id             String            @id @default(cuid())
  name           String
  description    String            @default("")
  gitUrl         String            @default("")
  framework      String            @default("")
  buildCommand   String            @default("npm run build")
  outputDir      String            @default("out")
  installCommand String            @default("npm install")
  userId         String
  user           User              @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  members        ProjectMember[]
  domains        Domain[]
  envVars        EnvVar[]
  webhooks       Webhook[]
  deployments    Deployment[]
  redirects      ProjectsRedirect[]
  functions      ProjectFunction[]
  notifications  NotificationChannel[]
  protection     DeploymentProtection?
  alias          String?           @default("")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Domain {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  verified       Boolean  @default(false)
  sslEnabled     Boolean  @default(false)
  sslProvisioned Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, name])
}

model EnvVar {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  value     String   @default("")
  buildTime Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, key])
}

model Webhook {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url          String
  secret       String   @default("")
  events       String   @default("[\"push\"]")
  active       Boolean  @default(true)
  githubRepo   String?  @default("")
  githubHookId String?  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NotificationChannel {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   @default("slack")
  url       String
  events    String   @default("[\"deploy.success\",\"deploy.failed\"]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeploymentProtection {
  id        String @id @default(cuid())
  projectId String @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled   Boolean @default(false)
  password  String  @default("")
}

model ProjectsRedirect {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source    String
  destination String
  type      String   @default("permanent")
  createdAt DateTime @default(now())
}

model ProjectFunction {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  method       String   @default("ANY")
  runtime      String   @default("nodejs")
  sourcePath   String   @default("")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, name])
}

model Deployment {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status     String    @default("pending")
  logs       String    @default("")
  branch     String    @default("main")
  commitSha  String    @default("")
  commitMsg  String    @default("")
  url        String    @default("")
  alias      String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SupportTicket {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  category   String   @default("general")
  status     String   @default("open")
  priority   String   @default("normal")
  projectId  String?
  messages   TicketReply[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}
