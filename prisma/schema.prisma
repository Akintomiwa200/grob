generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String       @id @default(cuid())
  name           String
  description    String       @default("")
  gitUrl         String       @default("")
  framework      String       @default("")
  buildCommand   String       @default("npm run build")
  outputDir      String       @default("out")
  installCommand String       @default("npm install")
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  domains        Domain[]
  envVars        EnvVar[]
  webhooks       Webhook[]
  deployments    Deployment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Domain {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  verified       Boolean  @default(false)
  sslEnabled     Boolean  @default(false)
  sslProvisioned Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, name])
}

model EnvVar {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  value     String   @default("")
  buildTime Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, key])
}

model Webhook {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  secret    String   @default("")
  events    String   @default("[\"push\"]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deployment {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String    @default("pending")
  logs      String    @default("")
  branch    String    @default("main")
  commitSha String    @default("")
  commitMsg String    @default("")
  url       String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
